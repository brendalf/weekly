rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User preferences
    match /preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Invites
    match /invitesByEmail/{email}/invites/{inviteId} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.token.email == email;
    }

    // Projects
    function isMember(projectId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.members;
    }

    match /projects/{projectId} {
      allow read: if request.auth != null &&
        (request.auth.uid in resource.data.members ||
        request.auth.uid == request.resource.data.ownerId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth != null && (
         request.auth.uid in resource.data.members ||
         (request.auth.token.email in resource.data.pendingInviteEmails &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingInviteEmails']))
      );
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      match /tasks/{taskId} {
        allow read, write: if isMember(projectId);
      }
      match /habits/{habitId} {
        allow read, write: if isMember(projectId);
        match /completions/{logId} {
          allow read, write: if isMember(projectId);
        }
      }
      match /habitProgress/{progressId} {
        allow read, write: if isMember(projectId);
      }
      match /activities/{actId} {
        allow read, write: if isMember(projectId);
      }
    }
  }
}
